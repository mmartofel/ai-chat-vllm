# ── LLM API ───────────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint (Ollama, vLLM, Llama Stack)
LLM_API_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=mistral

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=postgresql://admin:admin@localhost:5432/aichat

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme-replace-with-a-real-secret
JWT_EXPIRE_HOURS=8          # optional, default 8
COOKIE_SECURE=false         # set true in production (HTTPS)

# ── Vision model for image → text ────────────────────────────────────────────
# Local:      moondream  (via Ollama on LLM_API_URL)
# Production: llava-v1.6-mistral-7b  (via vLLM on a separate endpoint)
VISION_MODEL=moondream
# Vision API endpoint — defaults to LLM_API_URL/LLM_API_KEY if not set
# Set these to point at a separate vLLM service in production
VISION_BASE_URL=http://localhost:11434/v1
VISION_API_KEY=ollama

# ── Text → image generation service ─────────────────────────────────────────
# Local:      http://localhost:8100  (image_service/main.py, SDXL-Turbo on CPU)
# Production: http://image-service.apps.<cluster>/  (OpenShift GPU Deployment)
IMAGE_SERVICE_URL=http://localhost:8100

# ── MinIO / S3 object storage ─────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123
MINIO_BUCKET=images
# Public base URL returned to clients for viewing generated images
# Local:      http://localhost:9000/images  (bucket must be set to public)
# Production: https://<odf-route>/images  or a presigned URL base
MINIO_PUBLIC_BASE_URL=http://localhost:9000/images
